# Copy to `.env` and adjust as needed. Loaded automatically via python-dotenv by
# both the test suite (tests/fixtures/conftest.py) and the AI agent
# (agent/generate_tests.py).

# --- Application endpoints (override only if you changed the defaults) ---
BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000

# --- Test user (override for CI/staging; defaults match the app's seed data) ---
TEST_USER_EMAIL=joe@smith.com
TEST_USER_PASSWORD=joepassword

# --- AI agent: LLM provider keys (set the one matching your chosen --model) ---
# Gemini: get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional: override the default agent model (default: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash
