# Copy to `.env` and adjust as needed. Loaded automatically by the tests
# (via python-dotenv) and by the AI agent.

# --- Application endpoints (override only if you changed the defaults) ---
BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000

# --- Seeded test user ---
TEST_USER_EMAIL=joe@smith.com
TEST_USER_PASSWORD=joepassword

# --- AI agent (Gemini) ---
# Required to run agent/generate_tests.py. Get a key from
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: override the model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
